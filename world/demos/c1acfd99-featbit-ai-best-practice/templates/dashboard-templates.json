{
  "dashboards": {
    "ai-feature-flags-overview": {
      "title": "AI Feature Flags Overview",
      "description": "AI 功能 Feature Flag 概览面板",
      "widgets": [
        {
          "id": "flag-status-summary",
          "type": "stat",
          "title": "Active AI Flags",
          "query": "count(flags where key like 'ai-%' and status = 'on')"
        },
        {
          "id": "total-evaluations",
          "type": "timeseries",
          "title": "Flag Evaluations (24h)",
          "query": "sum(evaluations where flag_key like 'ai-%') by flag_key",
          "time_range": "24h"
        },
        {
          "id": "error-rate",
          "type": "stat",
          "title": "AI Flag Error Rate",
          "query": "rate(errors where flag_key like 'ai-%')",
          "thresholds": {
            "warning": 1,
            "critical": 5
          }
        },
        {
          "id": "latency-p99",
          "type": "stat",
          "title": "Evaluation Latency P99",
          "query": "percentile(evaluation_latency, 99)",
          "unit": "ms",
          "thresholds": {
            "warning": 50,
            "critical": 100
          }
        }
      ]
    },
    "ai-ab-testing": {
      "title": "AI A/B Testing Dashboard",
      "description": "AI 功能 A/B 测试监控面板",
      "widgets": [
        {
          "id": "experiment-results",
          "type": "table",
          "title": "Active Experiments",
          "columns": [
            "Experiment Name",
            "Flag Key",
            "Variations",
            "Sample Size",
            "Status"
          ],
          "query": "experiments where status = 'running'"
        },
        {
          "id": "conversion-rate-comparison",
          "type": "bar",
          "title": "Conversion Rate by Variation",
          "query": "avg(conversion_rate) group by variation for experiment 'ai-summary-strategy'"
        },
        {
          "id": "statistical-significance",
          "type": "stat",
          "title": "Statistical Significance",
          "query": "significance_score for experiment 'ai-summary-strategy'",
          "thresholds": {
            "success": 95,
            "warning": 80
          }
        },
        {
          "id": "user-satisfaction-by-strategy",
          "type": "timeseries",
          "title": "User Satisfaction by Strategy",
          "query": "avg(satisfaction_score) by variation",
          "time_range": "7d"
        }
      ]
    },
    "ai-cost-control": {
      "title": "AI Cost Control Dashboard",
      "description": "AI 成本控制监控面板",
      "widgets": [
        {
          "id": "daily-api-cost",
          "type": "timeseries",
          "title": "Daily AI API Cost",
          "query": "sum(api_cost) by model",
          "time_range": "30d",
          "unit": "USD"
        },
        {
          "id": "cost-per-user",
          "type": "stat",
          "title": "Avg Cost per User",
          "query": "avg(cost_per_user)",
          "unit": "USD",
          "thresholds": {
            "warning": 0.05,
            "critical": 0.10
          }
        },
        {
          "id": "usage-by-tier",
          "type": "pie",
          "title": "API Usage by Subscription Tier",
          "query": "sum(api_calls) by subscription_tier"
        },
        {
          "id": "rate-limit-hits",
          "type": "timeseries",
          "title": "Rate Limit Hits",
          "query": "count(rate_limit_exceeded)",
          "time_range": "24h"
        },
        {
          "id": "cost-forecast",
          "type": "stat",
          "title": "Monthly Cost Forecast",
          "query": "forecast(monthly_cost, end_of_month)",
          "unit": "USD",
          "thresholds": {
            "warning": 10000,
            "critical": 15000
          }
        }
      ]
    },
    "ai-release-monitoring": {
      "title": "AI Release Monitoring",
      "description": "AI 功能发布监控面板",
      "widgets": [
        {
          "id": "rollout-progress",
          "type": "gauge",
          "title": "Rollout Progress",
          "query": "percentage_rollout for flag 'ai-model-v2-enabled'",
          "thresholds": {
            "stages": [
              { "max": 5, "label": "Phase 1: Internal" },
              { "max": 20, "label": "Phase 2: Beta" },
              { "max": 50, "label": "Phase 3: Early Adopters" },
              { "max": 100, "label": "Phase 4: General Availability" }
            ]
          }
        },
        {
          "id": "error-rate-trend",
          "type": "timeseries",
          "title": "Error Rate Trend",
          "query": "rate(errors) for flag 'ai-model-v2-enabled'",
          "time_range": "7d",
          "thresholds": {
            "warning_line": 1,
            "critical_line": 5
          }
        },
        {
          "id": "user-feedback-score",
          "type": "timeseries",
          "title": "User Feedback Score",
          "query": "avg(feedback_score) by model_version",
          "time_range": "7d"
        },
        {
          "id": "recent-changes",
          "type": "table",
          "title": "Recent Flag Changes",
          "columns": [
            "Timestamp",
            "Flag Key",
            "Change Type",
            "Changed By",
            "Previous Value",
            "New Value"
          ],
          "query": "audit_log where flag_key like 'ai-%' order by timestamp desc limit 10"
        }
      ]
    }
  },
  "alerts": {
    "high-error-rate": {
      "name": "AI Flag High Error Rate",
      "description": "当 AI 相关 Flag 的错误率超过阈值时告警",
      "condition": {
        "query": "rate(errors where flag_key like 'ai-%')",
        "threshold": 5,
        "duration": "5m"
      },
      "severity": "critical",
      "notifications": [
        {
          "type": "slack",
          "channel": "#ai-alerts"
        },
        {
          "type": "pagerduty",
          "service_key": "${PAGERDUTY_SERVICE_KEY}"
        }
      ],
      "actions": [
        {
          "type": "trigger_webhook",
          "url": "${FEATBIT_API_URL}/api/flags/ai-model-v2-enabled/trigger/rollback",
          "method": "POST"
        }
      ]
    },
    "cost-threshold-exceeded": {
      "name": "AI Cost Threshold Exceeded",
      "description": "当 AI API 成本超过阈值时告警",
      "condition": {
        "query": "hourly_api_cost",
        "threshold": 100,
        "duration": "1h"
      },
      "severity": "warning",
      "notifications": [
        {
          "type": "slack",
          "channel": "#ai-cost-alerts"
        },
        {
          "type": "email",
          "recipients": ["ai-team@company.com", "finance@company.com"]
        }
      ]
    },
    "latency-degradation": {
      "name": "AI Flag Evaluation Latency High",
      "description": "当 Flag 评估延迟过高时告警",
      "condition": {
        "query": "percentile(evaluation_latency, 99) where flag_key like 'ai-%'",
        "threshold": 100,
        "duration": "5m"
      },
      "severity": "warning",
      "notifications": [
        {
          "type": "slack",
          "channel": "#ai-alerts"
        }
      ]
    },
    "experiment-significance-reached": {
      "name": "A/B Experiment Statistical Significance",
      "description": "当实验达到统计显著性时通知",
      "condition": {
        "query": "significance_score",
        "threshold": 95
      },
      "severity": "info",
      "notifications": [
        {
          "type": "slack",
          "channel": "#ai-experiments"
        },
        {
          "type": "email",
          "recipients": ["product@company.com", "data-science@company.com"]
        }
      ]
    }
  },
  "integrations": {
    "grafana": {
      "enabled": true,
      "url": "${GRAFANA_URL}",
      "annotations": {
        "flag_changes": true,
        "experiment_starts": true,
        "experiment_ends": true
      }
    },
    "datadog": {
      "enabled": true,
      "api_key": "${DATADOG_API_KEY}",
      "metrics": [
        "featbit.evaluations.count",
        "featbit.evaluations.latency",
        "featbit.errors.count"
      ]
    },
    "newrelic": {
      "enabled": true,
      "api_key": "${NEWRELIC_API_KEY}",
      "deployment_markers": true
    }
  }
}
